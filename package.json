{
  "name": "dartfit",
  "version": "1.0.0",
  "description": "Precision dart fitting using hand biometrics and biomechanical algorithms",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "generate-vapid": "node -e \"const wp=require('web-push');const k=wp.generateVAPIDKeys();console.log('VAPID_PUBLIC_KEY='+k.publicKey+'\\nVAPID_PRIVATE_KEY='+k.privateKey);\"",
    "coverage": "node scripts/coverage-analysis.js",
    "scrape": "node scripts/ingest/scraper.js",
    "scrape:target": "node scripts/ingest/scraper.js --source target",
    "scrape:winmau": "node scripts/ingest/scraper.js --source winmau",
    "scrape:reddragon": "node scripts/ingest/scraper.js --source reddragon",
    "scrape:harrows": "node scripts/ingest/scraper.js --source harrows",
    "import": "node scripts/ingest/import.js --file",
    "import:dry": "node scripts/ingest/import.js --file",
    "price-check": "node scripts/ingest/price-check.js",
    "price-check:apply": "node scripts/ingest/price-check.js --apply"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.12",
    "sharp": "^0.33.3",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
